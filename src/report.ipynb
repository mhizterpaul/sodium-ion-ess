   "source": [
    "## Stage 1: Parameter Derivation & Calibration\n",
    "Derives electrochemical parameters from theoretical molar mass and density."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# state: CALIBRATING\n",
    "from nfpp_sodium_ion.src.calibration.derivation import get_derived_parameters\n",
    "derived = get_derived_parameters()\n",
    "print(\"Derived Parameters:\", derived)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Stage 2: Cell Optimization\n",
    "Hessian-based design space reduction for optimal performance/cost."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# state: FILTERING\n",
    "from src.optimization_pipeline.optimize import NFPPoptimizer\n",
    "optimizer = NFPPoptimizer()\n",
    "optimal_theta = optimizer.run_optimization()\n",
    "print(\"Optimal Config (L_c, L_a, eps_c, eps_a, r_p):\", optimal_theta)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Stage 3: Stability Validation\n",
    "Physics consistency check using PyBaMM."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# state: REDUCING\n",
    "from src.optimization_pipeline.validate import StabilityValidator\n",
    "from nfpp_sodium_ion.src.cell_parameters.cell_alpha import get_parameter_values\n",
    "\n",
    "base_params = get_parameter_values()\n",
    "validator = StabilityValidator(base_params)\n",
    "results = validator.validate_electrochemical_performance()\n",
    "print(\"Validation Results:\", results)"
   ]
  },
  {
   "cell_type": "markdown",
